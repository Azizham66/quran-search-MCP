  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/quran-search-MCP"
  },
  "homepage": "https://github.com/your-username/quran-search-MCP#readme",
  "bugs": {
    "url": "https://github.com/your-username/quran-search-MCP/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "quran-search-engine": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
