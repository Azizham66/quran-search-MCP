    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest"
  },
  "keywords": [
    "mcp",
    "quran",
    "search",
    "islam",
    "server"
  ],
  "author": "Abdulaziz Hamzah",
