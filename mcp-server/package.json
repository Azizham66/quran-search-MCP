{
  "name": "quran-search-engine-mcp-server",
  "version": "0.1.0",
  "description": "MCP server adaptation for Quran Search Engine by Adel Benyahia",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
